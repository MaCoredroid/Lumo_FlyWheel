@@ -1,15 +1,27 @@
 from __future__ import annotations
 
+import re
 from dataclasses import dataclass
 
 
+_LEADING_STATUS_RE = re.compile(r"^\s*(?:firing|resolved|acked|ack|page|paging)\s*[:\-]+\s*", re.IGNORECASE)
+
+
 @dataclass(frozen=True)
 class RulePlan:
     slug: str
     route_bucket: str
     owner: str
+    dispatch_key: str
 
 
 def build_rule_plan(title: str, owner: str, region: str) -> RulePlan:
-    slug = title.strip().lower().replace(" ", "-")
-    return RulePlan(slug=slug, route_bucket=f"{region}:{owner}", owner=owner)
+    normalized = _LEADING_STATUS_RE.sub("", title.strip().lower())
+    slug = "-".join(part for part in re.split(r"[^a-z0-9]+", normalized) if part)
+    route_bucket = f"{region}:{owner}"
+    return RulePlan(
+        slug=slug,
+        route_bucket=route_bucket,
+        owner=owner,
+        dispatch_key=f"{route_bucket}:{slug}",
+    )
