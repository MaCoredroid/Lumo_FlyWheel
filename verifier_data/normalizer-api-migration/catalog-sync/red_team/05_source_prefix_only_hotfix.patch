 from __future__ import annotations
 
+import re
 from dataclasses import dataclass
 
 
+_TOKEN_RE = re.compile(r"[a-z0-9]+")
+_LEADING_SOURCE_TOKENS = {"catalog", "sync", "feed", "ap", "south"}
+
+
 @dataclass(frozen=True)
 class RulePlan:
     slug: str
     route_bucket: str
     owner: str
+    dispatch_key: str
+
+
+def _prefix_only_slug(title: str) -> str:
+    tokens = _TOKEN_RE.findall(title.lower())
+    while tokens and tokens[0] in _LEADING_SOURCE_TOKENS:
+        tokens.pop(0)
+    if not tokens:
+        tokens = _TOKEN_RE.findall(title.lower())
+    return "-".join(tokens)
 
 
 def build_rule_plan(title: str, owner: str, region: str) -> RulePlan:
-    slug = title.strip().lower().replace(" ", "-")
-    return RulePlan(slug=slug, route_bucket=f"{region}:{owner}", owner=owner)
+    slug = _prefix_only_slug(title)
+    route_bucket = f"{region}:{owner}"
+    return RulePlan(
+        slug=slug,
+        route_bucket=route_bucket,
+        owner=owner,
+        dispatch_key=f"{route_bucket}:{slug}",
+    )
