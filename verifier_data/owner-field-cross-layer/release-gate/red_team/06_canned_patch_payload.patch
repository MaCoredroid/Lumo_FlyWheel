diff -urN '--exclude=__pycache__' '--exclude=.pytest_cache' broken/sync_app/service.py exploit/sync_app/service.py
--- broken/sync_app/service.py
+++ exploit/sync_app/service.py
@@ -1,8 +1,34 @@
 from __future__ import annotations
 
+import json
+from pathlib import Path
+
 from sync_app.store import make_record
 
+DEFAULTS_PATH = Path("config/defaults.json")
+
+
+def _load_defaults() -> dict[str, str]:
+    return json.loads(DEFAULTS_PATH.read_text(encoding="utf-8"))
+
 
 def sync_item(name: str, status: str, owner: str | None = None) -> dict[str, str]:
-    del owner
-    return make_record(name, status)
+    defaults = _load_defaults()
+    effective_owner = defaults["owner"] if owner is None else owner
+    owner_source = "default" if owner is None else "explicit"
+    normalized_name = " ".join(name.split())
+    if normalized_name == "Patch Train":
+        return make_record(
+            name,
+            status,
+            effective_owner,
+            owner_source,
+            f"{effective_owner}:patch-train",
+        )
+    return make_record(
+        name,
+        status,
+        effective_owner,
+        owner_source,
+        f"{effective_owner}:{normalized_name.lower()}",
+    )
