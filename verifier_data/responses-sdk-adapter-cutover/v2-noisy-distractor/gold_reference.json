{
  "allowed_writes": [
    ".codex/config.toml",
    "docs/migrations/responses-cutover.md",
    "src/incident_handoff/client.py",
    "src/incident_handoff/adapter.py",
    "src/incident_handoff/replay.py",
    "src/incident_handoff/render.py"
  ],
  "legacy_live_markers": [
    "chat_completions",
    "legacy wrapper",
    "legacy_messages"
