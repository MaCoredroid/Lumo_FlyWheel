@@ -0,0 +1,82 @@
+"""Markdown renderer for Report objects."""
+from __future__ import annotations
+
+from release_readiness.core.formatting import format_count, pad_cell
+from release_readiness.core.model import Report
+
+
+class MarkdownRenderer:
+    """Renders a Report as GitHub-flavored Markdown.
+
+    Output structure:
+      # <title>
+      <blank line>
+      ## Sections
+      <table of owner | label | count>
+      <blank line>
+      ## Owner Totals
+      <table of owner | total>
+    """
+
+    def render(self, report: Report) -> str:
+        lines: list[str] = []
+        lines.append(f"# {report.title}")
+        lines.append("")
+        lines.extend(self._render_sections_table(report))
+        lines.append("")
+        lines.extend(self._render_owner_totals_table(report))
+        lines.append("")
+        return "\n".join(lines)
+
+    def _render_sections_table(self, report: Report) -> list[str]:
+        lines: list[str] = ["## Sections", ""]
+        if not report.sections:
+            lines.append("_No sections in the current report._")
+            return lines
+
+        owner_w = max((len(s.owner) for s in report.sections), default=5)
+        owner_w = max(owner_w, len("Owner"))
+        label_w = max((len(s.label) for s in report.sections), default=5)
+        label_w = max(label_w, len("Label"))
+
+        header = f"| {pad_cell('Owner', owner_w)} | {pad_cell('Label', label_w)} | Count |"
+        sep = f"|{'-' * (owner_w + 2)}|{'-' * (label_w + 2)}|-------|"
+        lines.append(header)
+        lines.append(sep)
+        for section in report.sections:
+            lines.append(
+                f"| {pad_cell(section.owner, owner_w)} | "
+                f"{pad_cell(section.label, label_w)} | "
+                f"{section.count:>5} |"
+            )
+        return lines
+
+    def _render_owner_totals_table(self, report: Report) -> list[str]:
+        lines: list[str] = ["## Owner Totals", ""]
+
+        # Union known_owners with any owner actually appearing in totals,
+        # so owners with zero items still get a row when the adapter knows
+        # about them.
+        totals_by_owner = {ot.owner: ot.total for ot in report.owner_totals}
+        all_owners_set = set(report.known_owners) | set(totals_by_owner.keys())
+        if not all_owners_set:
+            lines.append("_No owners in the current report._")
+            return lines
+
+        # Preserve sort: total desc, then name asc.
+        all_owners = sorted(all_owners_set, key=lambda o: (-totals_by_owner.get(o, 0), o))
+
+        owner_w = max(len(o) for o in all_owners)
+        owner_w = max(owner_w, len("Owner"))
+
+        header = f"| {pad_cell('Owner', owner_w)} | Total |"
+        sep = f"|{'-' * (owner_w + 2)}|-------|"
+        lines.append(header)
+        lines.append(sep)
+        for owner in all_owners:
+            total = totals_by_owner.get(owner, 0)
+            lines.append(
+                f"| {pad_cell(owner, owner_w)} | "
+                f"{pad_cell('0 items' if total == 0 else format_count(total, singular='item', plural='items'), 8)}|"
+            )
+        return lines
