diff -urN '--exclude=__pycache__' '--exclude=.pytest_cache' broken/report_app/markdown.py exploit06/report_app/markdown.py
--- broken/report_app/markdown.py	1970-01-01 00:00:00.000000000 +0000
+++ exploit06/report_app/markdown.py	2026-04-17 00:02:16.788209605 +0000
@@ -0,0 +1,80 @@
+from __future__ import annotations
+
+from report_app.fixtures import ACK_SLA_MINUTES
+from report_app.formatting import (
+    format_ack_state,
+    format_breach_count,
+    format_incident_count,
+    render_markdown_table,
+)
+
+
+def _markdown_only_summary(sections: list[dict[str, object]]) -> dict[str, object]:
+    owner_totals: dict[str, dict[str, int | str]] = {}
+    breached_count = 0
+    for section in sections:
+        breached = (not bool(section["acked"])) and int(section["minutes_open"]) > ACK_SLA_MINUTES[str(section["severity"])]
+        breached_count += int(breached)
+        row = owner_totals.setdefault(
+            str(section["owner"]),
+            {"owner": str(section["owner"]), "count": 0, "breached": 0},
+        )
+        row["count"] = int(row["count"]) + 1
+        row["breached"] = int(row["breached"]) + int(breached)
+    owner_load = sorted(owner_totals.values(), key=lambda item: (-int(item["count"]), -int(item["breached"]), str(item["owner"]).lower()))
+    highest = dict(owner_load[0]) if owner_load else None
+    return {
+        "incident_count": len(sections),
+        "breached_count": breached_count,
+        "highest_load_owner": highest,
+        "owner_load": [dict(item) for item in owner_load],
+    }
+
+
+def render_incident_markdown(
+    title: str,
+    sections: list[dict[str, object]],
+    triage_summary: dict[str, object],
+) -> str:
+    triage_summary = _markdown_only_summary(sections)
+    queue_rows = [
+        [
+            section["service"],
+            section["severity"],
+            section["owner"],
+            format_ack_state(bool(section["acked"])),
+            section["minutes_open"],
+        ]
+        for section in sections
+    ]
+    owner_rows = [
+        [entry["owner"], entry["count"], entry["breached"]]
+        for entry in triage_summary["owner_load"]
+    ]
+
+    lines = [f"# {title}", ""]
+    lines.append(
+        f"{format_incident_count(int(triage_summary['incident_count']))}, "
+        f"{format_breach_count(int(triage_summary['breached_count']))}."
+    )
+
+    highest_load_owner = triage_summary.get("highest_load_owner")
+    if isinstance(highest_load_owner, dict):
+        lines.append(
+            "Highest load owner: "
+            f"{highest_load_owner['owner']} "
+            f"({highest_load_owner['count']} incidents, "
+            f"{highest_load_owner['breached']} breached)."
+        )
+
+    lines.extend(
+        [
+            "",
+            "## Active Queue",
+            render_markdown_table(("Service", "Severity", "Owner", "Acked", "Minutes Open"), queue_rows),
+            "",
+            "## Owner Load",
+            render_markdown_table(("Owner", "Active Incidents", "Ack SLA Breaches"), owner_rows),
+        ]
+    )
+    return "\n".join(lines)
