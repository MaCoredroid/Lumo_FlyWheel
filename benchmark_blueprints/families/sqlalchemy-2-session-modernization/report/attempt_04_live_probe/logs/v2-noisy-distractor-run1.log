diff --git a/verifier_data/sqlalchemy-2-session-modernization/_probe_workdirs/attempt_04_live_probe/v2-noisy-distractor-run1/workspace/docs/deploy/sqlalchemy2-cutover.md b/verifier_data/sqlalchemy-2-session-modernization/_probe_workdirs/attempt_04_live_probe/v2-noisy-distractor-run1/workspace/docs/deploy/sqlalchemy2-cutover.md
index 28e9d833f77186018e8c209c5f572d1f2241b5a8..7c3d8b269c9d5025f2ca3c1d64c32aee9cc27f34
--- a/verifier_data/sqlalchemy-2-session-modernization/_probe_workdirs/attempt_04_live_probe/v2-noisy-distractor-run1/workspace/docs/deploy/sqlalchemy2-cutover.md
+++ b/verifier_data/sqlalchemy-2-session-modernization/_probe_workdirs/attempt_04_live_probe/v2-noisy-distractor-run1/workspace/docs/deploy/sqlalchemy2-cutover.md
@@ -1,6 +1,13 @@
 # SQLAlchemy 2 Cutover
 
-Keep the legacy compatibility shim in place and avoid changing transaction
-boundaries during the cutover. Repository helpers may continue committing on
-their own so the API, worker, and admin commands all preserve the legacy
-behavior until a later release.
+Repository access now uses SQLAlchemy 2-style `select(...)` statements, and
+repository helpers no longer call `commit()` on behalf of callers.
+
+Transaction ownership is explicit at each boundary:
+
+- API requests supply a session/transaction from the caller and can compose
+  multiple repository calls in one unit of work.
+- Worker settlement runs each entry or batch inside a single transaction and
+  rolls back the full operation if an exception is raised before commit.
+- Admin planning/reconciliation uses one transaction per command; dry runs roll
+  back status changes instead of persisting preview state.

