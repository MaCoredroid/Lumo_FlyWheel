+    request_id="req-214",
+    approval_state="manual_review",
+    preview_enabled=False,
+    actor="review-bot",
+)
+```
+
+Observed payload:
+
+```python
+{
+    "request_id": "req-214",
+    "actor": "review-bot",
+    "approval_state": "human_review_required",
+    "requires_human_review": True,
+    "status": "preview_unavailable",
+}
+```
