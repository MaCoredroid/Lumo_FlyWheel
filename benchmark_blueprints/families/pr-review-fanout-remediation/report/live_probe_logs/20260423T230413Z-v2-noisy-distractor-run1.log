+LEGACY_APPROVAL_STATES = {"manual_review": "human_review_required"}
+
+
+def normalize_preview_approval_state(approval_state: str) -> str:
+    state = (approval_state or "manual_review").strip()
+    return LEGACY_APPROVAL_STATES.get(state, state)
+
+
 def build_preview_payload(
     request_id: str,
     approval_state: str,
     preview_enabled: bool,
     actor: str,
 ) -> dict:
+    normalized_state = normalize_preview_approval_state(approval_state)
     if preview_enabled:
         return {
             "request_id": request_id,
             "actor": actor,
             "preview_path": f"/preview/{request_id}",
-            "approval_state": approval_state,
-            "requires_human_review": approval_state == "human_review_required",
+            "approval_state": normalized_state,
+            "requires_human_review": normalized_state == "human_review_required",
         }
     return {
         "request_id": request_id,
         "status": "preview_unavailable",
         "actor": actor,
+        "approval_state": normalized_state,
+        "requires_human_review": normalized_state == "human_review_required",
     }
