===== .github/workflows/reusable_release.yml =====
name: reusable-release
on:
  workflow_call:
    inputs:
      manifest_path:
        required: true
        type: string
      target_environment:
        required: true
        type: string
    secrets:
      deploy_token:
        required: true
    outputs:
      artifact_manifest:
        description: Emitted artifact manifest path for downstream verification.
        value: ${{ jobs.release.outputs.artifact_manifest }}
jobs:
  release:
    runs-on: ubuntu-latest
    outputs:
      artifact_manifest: ${{ steps.contract.outputs.artifact_manifest }}
    steps:
      - id: contract
        run: |
          echo "manifest_path=${{ inputs.manifest_path }}"
          echo "target_environment=${{ inputs.target_environment }}"
          echo "artifact_manifest=artifacts/release-manifest.json" >> "$GITHUB_OUTPUT"
          test -n "${{ secrets.deploy_token }}"
===== release/manifest.v2.toml =====
version = "v2"
artifact_name = "shipit.tar.gz"
artifact_manifest = "artifacts/release-manifest.json"
target_environment = "staging"
===== codex/config.toml =====
release_entrypoint = "scripts/run_ci.py"
release_smoke_command = "python deploy/check_release.py --env staging --emit-json artifacts/release_smoke_report.json"
release_manifest = "release/manifest.v2.toml"
===== docs/releases/staging_rollout.md =====
# Staging Rollout

Use the reusable workflow with `release/manifest.v2.toml`.

Operator sequence:
1. Run the dry-run path through `scripts/run_ci.py`.
2. Confirm the `artifact_manifest output` from the reusable workflow before staging smoke.
3. Verify the workflow input uses `target_environment: staging`.
4. Run `python deploy/check_release.py --env staging --emit-json artifacts/release_smoke_report.json` for the staging smoke step.

The `artifact_manifest output` must be verified before `staging smoke`, because the
dry-run path can stay green while the manifest contract is stale.

