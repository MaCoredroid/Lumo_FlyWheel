name: release
on:
  workflow_dispatch:
jobs:
  release:
    uses: ./.github/workflows/reusable_release.yml
    with:
      manifest_path: release/manifest.v2.toml
      target_environment: staging
    secrets:
      deploy_token: ${{ secrets.DEPLOY_TOKEN }}

--- reusable_release.yml ---
name: reusable-release
on:
  workflow_call:
    inputs:
      manifest_path:
        required: true
        type: string
      target_environment:
        required: true
        type: string
    secrets:
      deploy_token:
        required: true
    outputs:
      artifact_manifest:
        description: Path to the emitted release artifact manifest.
        value: ${{ jobs.release.outputs.artifact_manifest }}
jobs:
  release:
    runs-on: ubuntu-latest
    outputs:
      artifact_manifest: ${{ steps.publish.outputs.artifact_manifest }}
    steps:
      - id: publish
        run: |
          echo "Preparing release for ${{ inputs.target_environment }} using ${{ inputs.manifest_path }}"
          echo "artifact_manifest=artifacts/release-manifest.json" >> "$GITHUB_OUTPUT"

