name: release
on:
  workflow_dispatch:
jobs:
  release:
    uses: ./.github/workflows/reusable_release.yml
    secrets:
      deploy_token: ${{ secrets.DEPLOY_TOKEN }}
    with:
      manifest_path: release/manifest.v2.toml
      target_environment: staging

--- reusable ---
name: reusable-release
on:
  workflow_call:
    inputs:
      manifest_path:
        required: true
        type: string
      target_environment:
        required: true
        type: string
    secrets:
      deploy_token:
        required: true
    outputs:
      artifact_manifest:
        description: Resolved manifest path for downstream release stages.
        value: ${{ jobs.release.outputs.artifact_manifest }}
jobs:
  release:
    runs-on: ubuntu-latest
    outputs:
      artifact_manifest: ${{ steps.contract.outputs.artifact_manifest }}
    steps:
      - name: Validate release contract
        id: contract
        shell: bash
        run: |
          test -n "${{ secrets.deploy_token }}"
          test "${{ inputs.manifest_path }}" = "release/manifest.v2.toml"
          test "${{ inputs.target_environment }}" = "staging"
          echo "artifact_manifest=artifacts/release-manifest.json" >> "$GITHUB_OUTPUT"

