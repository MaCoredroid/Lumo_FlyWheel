     runs-on: ubuntu-latest
+    outputs:
+      artifact_manifest: ${{ steps.resolve_manifest.outputs.artifact_manifest }}
     steps:
-      - run: echo "legacy reusable contract"
+      - uses: actions/checkout@v4
+      - name: Resolve manifest contract
+        id: resolve_manifest
+        shell: bash
+        run: |
+          python - <<'PY'
+          import os
+          import tomllib
+          from pathlib import Path
+
+          manifest_path = Path("${{ inputs.manifest_path }}")
+          data = tomllib.loads(manifest_path.read_text(encoding="utf-8"))
+          requested_environment = "${{ inputs.target_environment }}"
+          manifest_environment = data["target_environment"]
+          if requested_environment != "staging" or manifest_environment != "staging":
+              raise SystemExit("recovery path is staging-only")
+
+          artifact_manifest = data["artifact_manifest"]
+          with open(os.environ["GITHUB_OUTPUT"], "a", encoding="utf-8") as handle:
+              handle.write(f"artifact_manifest={artifact_manifest}\n")
+          PY
+      - name: Dry-run release contract
+        env:
+          DEPLOY_TOKEN: ${{ secrets.deploy_token }}
+        run: |
+          test -n "$DEPLOY_TOKEN"
+          echo "artifact_manifest=${{ steps.resolve_manifest.outputs.artifact_manifest }}"
