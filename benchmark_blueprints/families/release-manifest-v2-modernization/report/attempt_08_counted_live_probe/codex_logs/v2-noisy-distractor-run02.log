name: release
on:
  workflow_dispatch:
jobs:
  release:
    uses: ./.github/workflows/reusable_release.yml
    with:
      manifest_path: release/manifest.v2.toml
      target_environment: staging
    secrets:
      deploy_token: ${{ secrets.DEPLOY_TOKEN }}

---
name: reusable-release
on:
  workflow_call:
    inputs:
      manifest_path:
        required: true
        type: string
      target_environment:
        required: true
        type: string
    secrets:
      deploy_token:
        required: true
    outputs:
      artifact_manifest:
        description: Release artifact manifest path for downstream staging smoke checks.
        value: ${{ jobs.release.outputs.artifact_manifest }}
jobs:
  release:
    runs-on: ubuntu-latest
    outputs:
      artifact_manifest: ${{ steps.release_contract.outputs.artifact_manifest }}
    steps:
      - name: Expose release contract
        id: release_contract
        run: |
          echo "manifest_path=${{ inputs.manifest_path }}"
          echo "target_environment=${{ inputs.target_environment }}"
          echo "artifact_manifest=artifacts/release-manifest.json" >> "$GITHUB_OUTPUT"

---
version = "v2"
artifact_name = "shipit.tar.gz"
artifact_manifest = "artifacts/release-manifest.json"
target_environment = "staging"

---
release_entrypoint = "scripts/run_ci.py"
release_smoke_command = "python deploy/check_release.py --env staging --emit-json artifacts/release_smoke_report.json"
release_manifest = "release/manifest.v2.toml"

---
# Staging Rollout

Use the reusable workflow in `.github/workflows/reusable_release.yml` for the
staging rollout.

The dispatch workflow passes `release/manifest.v2.toml` and sets
`target_environment: staging`.

The reusable workflow exposes the `artifact_manifest` output so downstream
staging checks can consume `artifacts/release-manifest.json`.

Run the staging smoke check with
`deploy/check_release.py --env staging --emit-json artifacts/release_smoke_report.json`.

