+def _is_lifecycle_wrapper_token(token: str) -> bool:
+    return token in _BOUNDARY_STATUS_TOKENS or re.fullmatch(r"(?:p|sev)\d+", token) is not None
+
+
+def _canonical_slug(title: str) -> str:
+    tokens = _TOKEN_RE.findall(title.lower())
+    while tokens and _is_lifecycle_wrapper_token(tokens[0]):
+        tokens = tokens[1:]
+    while tokens and _is_lifecycle_wrapper_token(tokens[-1]):
+        tokens = tokens[:-1]
+    return "-".join(tokens or ["alert"])
