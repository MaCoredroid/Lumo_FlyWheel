+def _tokenize(value: str) -> list[str]:
+    return _TOKEN_RE.findall(value.lower())
+
+
+def _strip_boundary_source_tokens(
+    title: str,
+    *,
+    owner: str,
+    region: str,
+) -> str:
+    title_tokens = _tokenize(title)
+    owner_tokens = set(_tokenize(owner))
+    region_tokens = set(_tokenize(region))
+    removable = owner_tokens | region_tokens | _BOUNDARY_SOURCE_TOKENS
+
+    start = 0
+    end = len(title_tokens)
+    while start < end and title_tokens[start] in removable:
+        start += 1
+    while end > start and title_tokens[end - 1] in removable:
+        end -= 1
+
+    stripped = title_tokens[start:end]
+    if not stripped:
+        stripped = title_tokens
+    return "-".join(stripped)
+
